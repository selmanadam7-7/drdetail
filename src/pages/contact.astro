---
import Layout from '../layouts/Layout.astro';
import { BIZ } from '../data/site.mjs';
---
<Layout title="Book Today | Dr. Detail Fargo, ND" description="Book Dr. Detail in Fargo, ND for premium auto detailing at our studio. Serving the Fargo-Moorhead metro." section="contact">
  <div class="detail-hero"><div class="dh-img"><img src="/svc-correction.jpg" alt="Detailing in progress at Dr. Detail in Fargo, ND" /></div><div class="container">
    <div class="breadcrumb"><a href="/">Home</a><span class="sep">/</span><span>Contact</span></div>
    <span class="label">Get In Touch</span>
    <h1>Book <span class="am">Today</span></h1>
    <p class="lead">Fill out the form and we'll get back to you fast — usually the same day. Or call, we'd love to talk shop.</p>
  </div></div>
  <section class="section"><div class="container contact-layout">
    <div class="quote-form" style="padding:0;overflow:hidden;background:transparent;border:none">
      <iframe src="https://api.cleanerclicks.com/widget/form/xAg7GX9e75KczDzdVB9h" style="width:100%;min-height:894px;border:none;border-radius:10px;background:transparent;display:block" id="inline-xAg7GX9e75KczDzdVB9h" data-layout="{'id':'INLINE'}" data-trigger-type="alwaysShow" data-trigger-value="" data-activation-type="alwaysActivated" data-activation-value="" data-deactivation-type="neverDeactivate" data-deactivation-value="" data-form-name="Website Form" data-height="894" data-layout-iframe-id="inline-xAg7GX9e75KczDzdVB9h" data-form-id="xAg7GX9e75KczDzdVB9h" title="Website Form"></iframe>
    </div>
    <div class="contact-info">
      <div class="row"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.4 2.1L8 9.6a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2z"/></svg></div><div><h4>Call or Text</h4><a href={BIZ.phoneHref}>{BIZ.phone}</a><div class="tiny">Call or text anytime</div></div></div>
      <div class="row"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg></div><div><h4>Email</h4><a href={`mailto:${BIZ.email}`}>{BIZ.email}</a><div class="tiny">Placeholder — add real email</div></div></div>
      <div class="row"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></div><div><h4>Location</h4><p><strong style="color:#fff">{BIZ.address}</strong><br>Drop-off at our Fargo studio · serving the whole metro</p></div></div>
      <div class="row"><div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div><div><h4>Hours</h4><p>{BIZ.hours}</p></div></div>
      <iframe class="map-ph" title="Dr. Detail — 4402 27th St N, Fargo, ND" loading="lazy" referrerpolicy="no-referrer-when-downgrade" style="width:100%;border:1px solid var(--line);border-radius:6px;display:block;filter:grayscale(.4) contrast(1.05)" src={BIZ.mapEmbed}></iframe>
    </div>
  </div></section>
</Layout>
