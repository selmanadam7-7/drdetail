---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pricing & Membership | Dr. Detail Fargo, ND" description="Simple, transparent auto detailing pricing in Fargo, ND — Express, Full Detail, and Ceramic packages, plus monthly Detail Club memberships that keep your vehicle clean year-round." section="pricing">
  <div class="detail-hero"><div class="dh-img"><img src="/svc-exterior.jpg" alt="Foam wash at Dr. Detail in Fargo, ND" /></div><div class="container">
    <div class="breadcrumb"><a href="/">Home</a><span class="sep">/</span><span>Pricing</span></div>
    <span class="label">Packages</span>
    <h1>Simple <span class="am">Pricing</span></h1>
    <p class="lead">Honest packages, no surprises. Final pricing depends on vehicle size and condition — book today for an exact price.</p>
  </div></div>

  <section class="section"><div class="container">
    <div class="sec-head center reveal"><span class="label center">One-Time Details</span><h2>Pay-As-You-Go Packages</h2></div>
    <div class="price-grid">
      <div class="price-card reveal"><h3>Express</h3><p class="ts">A fast refresh for the regular driver</p><div class="from">Starting at</div><div class="price">$89<small>/ visit</small></div>
        <ul><li>Hand wash &amp; dry</li><li>Wheels &amp; tires cleaned + dressed</li><li>Windows in &amp; out</li><li>Quick interior vacuum</li><li>Console &amp; dash wipe-down</li></ul>
        <a href="/contact/" class="btn btn-outline">Book Express</a></div>
      <div class="price-card feat reveal"><h3>Full Detail</h3><p class="ts">Our most-loved inside-and-out package</p><div class="from">Starting at</div><div class="price">$229<small>/ visit</small></div>
        <ul><li>Everything in Express</li><li>Deep interior shampoo &amp; steam</li><li>Leather clean &amp; condition</li><li>Clay bar + wax</li><li>Pet hair &amp; odor treatment</li><li>Door jambs &amp; detailed vents</li></ul>
        <a href="/contact/" class="btn btn-primary">Book Full Detail</a></div>
      <div class="price-card reveal"><h3>Ceramic</h3><p class="ts">Maximum protection &amp; gloss</p><div class="from">Starting at</div><div class="price">$350<small>+</small></div>
        <ul><li>Everything in Full Detail</li><li>Professional ceramic coating</li><li>Up to 3-year protection</li><li>Hydrophobic, self-cleaning finish</li><li>Deep, glass-like gloss</li></ul>
        <a href="/contact/" class="btn btn-outline">Book Ceramic</a></div>
    </div>
    <p class="price-note">Starting estimates for standard vehicles. Trucks, SUVs &amp; heavily soiled vehicles may vary. <a href="/contact/">Book today →</a></p>
  </div></section>

  <section class="section" id="membership" style="padding-top:0"><div class="container">
    <div class="sec-head center reveal"><span class="label center">Detail Club</span><h2>Monthly Memberships</h2><p>Keep your vehicle clean all year for a fixed monthly price. Pick a plan, set your schedule, and we handle the rest — no booking back and forth, no surprise costs.</p></div>
    <div class="price-grid">
      <div class="price-card reveal"><h3>Maintenance</h3><p class="ts">Two washes a month, handled for you</p><div class="from">Membership</div><div class="price">$89<small>/ month</small></div>
        <ul><li><strong style="color:#fff">Two exterior maintenance washes every month</strong></li><li>Hand wash + spray-wax sealant each visit</li><li>Wheels, tires &amp; tire shine</li><li>Quick interior vacuum + wipe-down</li><li>Glass in &amp; out</li><li>Priority member booking</li><li>10% off any additional service</li></ul>
        <a href="/contact/" class="btn btn-outline">Join Maintenance</a></div>
      <div class="price-card feat reveal"><h3>Signature</h3><p class="ts">A deeper detail, every single month</p><div class="from">Membership</div><div class="price">$149<small>/ month</small></div>
        <ul><li><strong style="color:#fff">One full maintenance detail every month</strong></li><li>Everything in Maintenance, plus:</li><li>Interior steam of high-touch areas</li><li>Leather &amp; vinyl conditioning</li><li>Clay bar + wax as needed</li><li>Free interior add-ons (pet hair &amp; spot cleaning)</li><li>15% off full details, ceramic &amp; headlight restoration</li></ul>
        <a href="/contact/" class="btn btn-primary">Join Signature</a></div>
    </div>
    <p class="price-note">All memberships are month-to-month — cancel anytime, no contract. New members start with a one-time Full Detail to bring the vehicle to baseline, then monthly maintenance keeps it there. Pricing shown is for standard cars; trucks &amp; SUVs are slightly higher. <a href="/contact/">Ask about membership →</a></p>
  </div></section>
</Layout>
