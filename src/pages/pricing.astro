---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Pricing | Dr. Detail Fargo, ND" description="Simple, transparent auto detailing pricing in Fargo, ND. Express, Full Detail, and Ceramic packages." section="pricing">
  <div class="detail-hero"><div class="dh-img"><img src="/svc-exterior.jpg" alt="Foam wash at Dr. Detail in Fargo, ND" /></div><div class="container">
    <div class="breadcrumb"><a href="/">Home</a><span class="sep">/</span><span>Pricing</span></div>
    <span class="label">Packages</span>
    <h1>Simple <span class="am">Pricing</span></h1>
    <p class="lead">Honest packages, no surprises. Final pricing depends on vehicle size and condition — book today for an exact price.</p>
  </div></div>
  <section class="section"><div class="container">
    <div class="price-grid">
      <div class="price-card reveal"><h3>Express</h3><p class="ts">A fast refresh for the regular driver</p><div class="from">Starting at</div><div class="price">$89<small>/ visit</small></div>
        <ul><li>Hand wash &amp; dry</li><li>Wheels &amp; tires cleaned + dressed</li><li>Windows in &amp; out</li><li>Quick interior vacuum</li><li>Console &amp; dash wipe-down</li></ul>
        <a href="/contact/" class="btn btn-outline">Book Express</a></div>
      <div class="price-card feat reveal"><h3>Full Detail</h3><p class="ts">Our most-loved inside-and-out package</p><div class="from">Starting at</div><div class="price">$229<small>/ visit</small></div>
        <ul><li>Everything in Express</li><li>Deep interior shampoo &amp; steam</li><li>Leather clean &amp; condition</li><li>Clay bar + hand wax</li><li>Pet hair &amp; odor treatment</li><li>Door jambs &amp; detailed vents</li></ul>
        <a href="/contact/" class="btn btn-primary">Book Full Detail</a></div>
      <div class="price-card reveal"><h3>Ceramic</h3><p class="ts">Maximum protection &amp; gloss</p><div class="from">Starting at</div><div class="price">$699<small>+</small></div>
        <ul><li>Everything in Full Detail</li><li>Multi-stage paint correction</li><li>Professional ceramic coating</li><li>Up to 5-year protection</li><li>Hydrophobic, glass-like finish</li><li>Maintenance plan included</li></ul>
        <a href="/contact/" class="btn btn-outline">Book Ceramic</a></div>
    </div>
    <p class="price-note">Starting estimates for standard vehicles. Trucks, SUVs &amp; heavily soiled vehicles may vary. <a href="/contact/">Book today →</a></p>
  </div></section>
</Layout>
