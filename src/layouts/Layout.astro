---
import '../styles/global.css';
import { BIZ, SERVICES, AREAS } from '../data/site.mjs';

const { title, description, section = '' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/hero.jpg', Astro.site).href;
const year = new Date().getFullYear();

const localBusiness = {
  "@context": "https://schema.org",
  "@type": ["AutoWash", "LocalBusiness"],
  "name": "Dr. Detail",
  "image": ogImage,
  "description": "Fargo's premium auto detailing studio. Interior and exterior detailing, full details, and ceramic coating.",
  "@id": "https://drdetailfargo.com/",
  "url": "https://drdetailfargo.com/",
  "telephone": BIZ.phone,
  "priceRange": "$$",
  "address": { "@type": "PostalAddress", "streetAddress": BIZ.street, "addressLocality": BIZ.city, "addressRegion": BIZ.region, "postalCode": BIZ.zip, "addressCountry": "US" },
  "geo": { "@type": "GeoCoordinates", "latitude": 46.9392952, "longitude": -96.8221942 },
  "areaServed": ["Fargo, ND", "West Fargo, ND", "Moorhead, MN", "Dilworth, MN", "Horace, ND"],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "08:00", "closes": "18:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "16:00" }
  ],
  "email": BIZ.email,
  "currenciesAccepted": "USD",
  "paymentAccepted": "Cash, Credit Card, Debit Card, Digital Payments",
  "sameAs": [BIZ.reviewUrl]
};
const navItems = [
  { label: 'Home', href: '/', key: 'home' },
  { label: 'About', href: '/about/', key: 'about' },
  { label: 'Services', href: '/services/', key: 'services' },
  { label: 'Gallery', href: '/gallery/', key: 'gallery' },
  { label: 'Areas', href: '/areas/', key: 'areas' },
  { label: 'Pricing', href: '/pricing/', key: 'pricing' },
  { label: 'Contact', href: '/contact/', key: 'contact' },
];
const phoneSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.4 2.1L8 9.6a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2z"/></svg>';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content="auto detailing Fargo, car detailing Fargo ND, ceramic coating Fargo, car detailing studio Fargo, interior detailing, headlight restoration, Dr. Detail" />
<meta name="author" content="Dr. Detail" />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonical} />
<meta property="og:type" content="business.business" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:locality" content="Fargo" /><meta property="og:region" content="ND" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta name="twitter:card" content="summary_large_image" />
<link rel="icon" type="image/png" href="/dr-detail-bubble.png" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Anton&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap" rel="stylesheet" />
<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
<slot name="head" />
</head>
<body>
<a href="#main" class="skip-link">Skip to content</a>

<div class="topbar" id="topbar">
  <div class="announce"><div class="container">
    <span class="hide-sm">★★★★★ Premium Detailing · Fargo-Moorhead Metro</span>
    <span class="sep hide-sm">/</span>
    <span><span class="hl">New customers:</span> $25 off your first detail</span>
    <span class="sep">/</span>
    <a href={BIZ.phoneHref} set:html={phoneSvg + BIZ.phone}></a>
  </div></div>
  <header class="site-header" id="siteHeader"><div class="container nav-inner">
    <a href="/" class="logo" aria-label="Dr. Detail home"><img src="/dr-detail-mascot.png" class="logo-img" alt="Dr. Detail" onerror="this.style.display='none';this.nextElementSibling.style.display='grid'" /><span class="mk" style="display:none">D</span>Dr.&nbsp;Detail</a>
    <nav class="nav-links" id="navLinks" aria-label="Main navigation">
      {navItems.map(n => <a href={n.href} class={`nav-link${section === n.key ? ' active' : ''}`}>{n.label}</a>)}
      <a href={BIZ.phoneHref} class="nav-phone" set:html={phoneSvg + BIZ.phone}></a>
      <span class="nav-cta"><a href="/contact/" class="btn btn-primary">Book Today</a></span>
    </nav>
    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false"><span></span><span></span><span></span></button>
  </div></header>
</div>
<div class="nav-backdrop" id="navBackdrop"></div>

<main id="main">
  <slot />
</main>

<footer class="site-footer">
  <div class="bubbles" aria-hidden="true">
    <span class="bubble" style="width:54px;height:54px;right:6%;top:18%;opacity:.28;animation:bubA 19s ease-in-out infinite"></span>
    <span class="bubble" style="width:26px;height:26px;left:5%;bottom:26%;opacity:.4;animation:bubC 15s ease-in-out infinite 1s backwards"></span>
  </div>
  <div class="container">
  <div class="footer-grid">
    <div class="footer-col">
      <a class="logo" href="/" aria-label="Dr. Detail"><img src="/dr-detail-mascot.png" class="logo-img" alt="Dr. Detail" onerror="this.style.display='none';this.nextElementSibling.style.display='grid'" /><span class="mk" style="display:none">D</span>Dr.&nbsp;Detail</a>
      <p>Fargo's premium auto detailing studio. Showroom-quality results, careful hands, and products that protect your investment.</p>
      <div class="footer-social">
        <a href={BIZ.reviewUrl} target="_blank" rel="noopener" aria-label="Google"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 11v2.8h4a3.9 3.9 0 0 1-1.7 2.6l2.6 2A7.9 7.9 0 0 0 20 12c0-.6 0-1.1-.2-1.6z"/><path d="M12 20a8 8 0 0 0 5.5-2l-2.6-2a4.8 4.8 0 0 1-7.2-2.5l-2.7 2A8 8 0 0 0 12 20z" opacity=".7"/></svg></a>
      </div>
    </div>
    <div class="footer-col"><h4>Services</h4>{SERVICES.map(s => <a href={`/services/${s.slug}/`}>{s.title}</a>)}</div>
    <div class="footer-col"><h4>Service Areas</h4>{AREAS.map(a => <a href={`/areas/${a.slug}/`}>{a.name.split(',')[0]}</a>)}</div>
    <div class="footer-col"><h4>Company</h4><a href="/about/">About</a><a href="/gallery/">Gallery</a><a href="/pricing/">Pricing</a><a href="/faq/">FAQ</a><a href="/contact/">Contact</a><a href={BIZ.phoneHref}>{BIZ.phone}</a></div>
  </div>
  <div class="footer-bottom"><div>© {year} Dr. Detail · Fargo, North Dakota</div><div>Website by <a href="https://cleanerclicks.com" target="_blank" rel="noopener">Cleaner Clicks</a></div></div>
</div></footer>

<div class="mobile-cta">
  <a href={BIZ.phoneHref} class="btn btn-outline" set:html={'<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"width:16px;height:16px\"><path d=\"M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.6A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1.9.3 1.8.6 2.7a2 2 0 0 1-.4 2.1L8 9.6a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.1-.5c.9.3 1.8.5 2.7.6a2 2 0 0 1 1.7 2z\"/></svg>Call'}></a>
  <a href="/contact/" class="btn btn-primary">Book Today</a>
</div>

<div class="lightbox" id="lightbox" role="dialog" aria-label="Image preview"><button class="lb-close" id="lbClose" aria-label="Close">&times;</button><img id="lbImg" src="" alt="Detailing work" /></div>

<script is:inline>
  const header=document.getElementById('siteHeader');
  if(header){const onScroll=()=>header.classList.toggle('scrolled',window.scrollY>20);window.addEventListener('scroll',onScroll,{passive:true});onScroll();}
  const body=document.body,toggle=document.getElementById('navToggle'),backdrop=document.getElementById('navBackdrop');
  function closeMenu(){body.classList.remove('nav-open');document.documentElement.classList.remove('nav-lock');if(toggle)toggle.setAttribute('aria-expanded','false');}
  if(toggle){toggle.addEventListener('click',()=>{if(body.classList.contains('nav-open')){closeMenu();}else{body.classList.add('nav-open');document.documentElement.classList.add('nav-lock');toggle.setAttribute('aria-expanded','true');}});}
  if(backdrop){backdrop.addEventListener('click',closeMenu);}
  document.querySelectorAll('.nav-link').forEach(l=>l.addEventListener('click',closeMenu));
  const lb=document.getElementById('lightbox'),lbImg=document.getElementById('lbImg');
  if(lb){document.addEventListener('click',e=>{const g=e.target.closest('.gal-item');if(g){lbImg.src=g.getAttribute('data-img');lb.classList.add('open');}});
    document.getElementById('lbClose').addEventListener('click',()=>lb.classList.remove('open'));
    lb.addEventListener('click',e=>{if(e.target===lb)lb.classList.remove('open');});
    document.addEventListener('keydown',e=>{if(e.key==='Escape')lb.classList.remove('open');});}
  (function(){const ba=document.getElementById('ba');if(!ba)return;const before=ba.querySelector('.ba-before'),line=ba.querySelector('.ba-line');let drag=false;
    function set(x){const r=ba.getBoundingClientRect();let p=(x-r.left)/r.width*100;p=Math.max(0,Math.min(100,p));before.style.clipPath='inset(0 '+(100-p)+'% 0 0)';line.style.left=p+'%';}
    ba.addEventListener('pointerdown',e=>{drag=true;ba.setPointerCapture(e.pointerId);set(e.clientX);});
    ba.addEventListener('pointermove',e=>{if(drag)set(e.clientX);});
    ba.addEventListener('pointerup',()=>drag=false);})();
  const faqEl=document.getElementById('faq');
  if(faqEl){faqEl.addEventListener('click',e=>{const q=e.target.closest('.faq-q');if(!q)return;const item=q.parentElement,ans=item.querySelector('.faq-a'),open=item.classList.contains('open');
    faqEl.querySelectorAll('.faq-item.open').forEach(i=>{i.classList.remove('open');i.querySelector('.faq-a').style.maxHeight=null;});
    if(!open){item.classList.add('open');ans.style.maxHeight=ans.scrollHeight+'px';}});}
  const io=new IntersectionObserver(es=>{es.forEach(en=>{if(en.isIntersecting){en.target.classList.add('in');io.unobserve(en.target);}});},{threshold:.08,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));
</script>
<script src="https://api.cleanerclicks.com/js/form_embed.js" is:inline></script>
<script src="https://beta.leadconnectorhq.com/loader.js" data-resources-url="https://beta.leadconnectorhq.com/chat-widget/loader.js" data-widget-id="6a20c9a895223f3846a1af12" is:inline></script>
</body>
</html>
